# Optional development shortcut. Leave empty to start normally.
# Use the visible level number, e.g. 3 starts in Level 3.
VITE_START_LEVEL=

# Show debug labels like P1, P2, ... on platforms in development.
VITE_SHOW_PLATFORM_NUMBERS=false

# Start directly in the boss arena with the boss already defeated.
VITE_START_BOSS_DEFEATED=false
